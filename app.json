{
  "$schema": "https://raw.githubusercontent.com/expo/expo/main/docs/public/static/schemas/v54.0.0/app-config-schema.json",
  "expo": {
    "name": "Queens Rush",
    "slug": "queens-rush",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "queensrush",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.venky.queensrush"
    },
    "android": {
      "package": "com.venky.queensrush",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#f8f9fa",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#111827",
          "image": "./assets/images/splash-icon.png"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "shrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "react-native-google-mobile-ads"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "3b16cc4f-d840-4346-a36c-97901434b128"
      }
    }
  },
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-5818429762885270~9992420567",
    "ios_app_id": "ca-app-pub-5818429762885270~9992420567"
  }
}


